{
  "maxWorkers": 1,
  "moduleFileExtensions": ["js", "json", "tsx", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "setupFiles": ["<rootDir>/jest-env.ts"],
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)sx?$": [
      "ts-jest",
      {
        "tsconfig": {
          "module": "commonjs",
          "moduleResolution": "node",
          "resolvePackageJsonExports": false,
          "jsx": "react"
        }
      }
    ]
  },
  "moduleNameMapper": {
    "^src/(.*)$": "<rootDir>/../src/$1"
  }
}
